# --- Ploi SSH deploy (npm run plugins:deploy) ---
# Default deploy: omb-headless-core + omb-form-builder only.
# Theme (acf-json): npm run plugins:deploy -- --with-theme  (needs PLOI_THEMES_PATH)
# Mu-plugin: npm run plugins:deploy -- --with-mu-plugin  (needs PLOI_MU_PLUGINS_PATH)
# PLOI_SSH_HOST=157.180.68.216
# PLOI_SSH_USER=ploi
# PLOI_PLUGINS_PATH=/home/ploi/backend.salonora.eu/public/wp-content/plugins
# PLOI_THEMES_PATH=/home/ploi/backend.salonora.eu/public/wp-content/themes
# PLOI_MU_PLUGINS_PATH=/home/ploi/backend.salonora.eu/public/wp-content/mu-plugins

# --- WordPress (required for real content) ---
# REST API root (no trailing slash)
WORDPRESS_API_URL=https://your-wordpress.test/wp-json

# Public WordPress site URL — media + CF7 (no /wp-json)
WORDPRESS_BASE_URL=https://your-wordpress.test

# --- Next.js public URL (required) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: Basic auth for server-side REST (e.g. menu-items 401) ---
# WORDPRESS_APPLICATION_USER=
# WORDPRESS_APPLICATION_PASSWORD=

# --- Blog archive page slug (single path segment for breadcrumbs + revalidation hints) ---
# Defaults to "blog" when unset.
# WORDPRESS_BLOG_PAGE_SLUG=blog
# WORDPRESS_BLOG_PAGE_SLUG_NL=blog
# WORDPRESS_BLOG_PAGE_SLUG_EN=blog

# --- Blog single template (preferred): ACF options page omb-templates-settings, field blog_single_sections ---
# See docs/blog-single-template.md. OMB /globals may expose a `templates` object.

# --- Blog single layout page (legacy fallback only; ACF is_blog_single_layout) ---
# WORDPRESS_BLOG_SINGLE_LAYOUT_SLUG=blog-single-layout
# WORDPRESS_BLOG_SINGLE_LAYOUT_SLUG_NL=blog-single-layout
# WORDPRESS_BLOG_SINGLE_LAYOUT_SLUG_EN=blog-single-layout

# --- Case study archive slug (single path segment for single-case-study breadcrumbs) ---
# Defaults to "case-studies" when unset (match CPT rewrite slug in WordPress).
# WORDPRESS_CASE_STUDY_PAGE_SLUG=case-studies
# WORDPRESS_CASE_STUDY_PAGE_SLUG_NL=casestudies
# WORDPRESS_CASE_STUDY_PAGE_SLUG_EN=case-studies

# --- Homepage (/{lang}/): WordPress Settings → Reading “Homepage” (static page) via OMB `/globals` + Polylang. ---
# Optional fallback if Reading is not “A static page” or the plugin is older / slug missing:
# HOMEPAGE_SLUG=home
# HOMEPAGE_SLUG_NL=home
# HOMEPAGE_SLUG_EN=home

# --- Legal / FAQ pages (EN: privacy-policy, terms-conditions, faqs; NL: privacybeleid, algemene-voorwaarden, veelgestelde-vragen) ---
# ACF layouts: legal_content (body WYSIWYG), faq (repeater). See WORDPRESS-ACF-legal-content.md.
# Seed live copy into empty pages: node src/lib/legal/seed-legal-pages.mjs [--faq]
# Next falls back to src/lib/legal/ only when WP page is missing or has no content/sections.

# --- Menus: numeric menu IDs per location + language (REST menu-items) ---
# WP_MENU_PRIMARY_NL=
# WP_MENU_PRIMARY_EN=
# WP_MENU_FOOTER_NL=
# WP_MENU_FOOTER_EN=
# WP_MENU_LEGAL_NL=
# WP_MENU_LEGAL_EN=
# Legacy alias pattern also supported:
# WORDPRESS_MENU_PRIMARY_NL=

# --- On-demand revalidation (POST /api/revalidate) ---
# REVALIDATION_SECRET=

# --- Contact Form 7 (form_embed section + post/case featured forms) ---
# NEXT_PUBLIC_DEFAULT_CF7_FORM_ID=

# --- OMB Form Builder (free demo section → `POST /api/forms/free-demo` → `…/custom-form-builder/v1/public/forms/{id}/submit`) ---
# Must match `CFB_HEADLESS_SUBMIT_SECRET` in WordPress `wp-config.php`. Alias env names supported.
# If all three are unset, Next uses WordPress **Integrations** (ACF): `omb_form_builder_submit_secret`, then `revalidation_secret`.
# OMB_FORM_BUILDER_SUBMIT_SECRET=
# CFB_HEADLESS_SUBMIT_SECRET=
# (also accepts `REVALIDATION_SECRET` as the same Bearer value when the dedicated vars above are unset)

# --- Default trailing icon for blue CTAs (Button variant ctaBrand); overrides built-in Salonora asset URL ---
# NEXT_PUBLIC_DEFAULT_CTA_BRAND_ARROW_URL=

# --- i18n overrides (defaults: nl, nl+en) ---
# DEFAULT_LOCALE=nl
# SUPPORTED_LOCALES=nl,en

# --- Rare: CPT REST base if different from post type slug ---
# WORDPRESS_SERVICE_REST_BASE=service
# WORDPRESS_TESTIMONIAL_REST_BASE=testimonial
# WORDPRESS_CASE_STUDY_REST_BASE=case_study
