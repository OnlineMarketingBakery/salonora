# --- WordPress (required for real content) ---
# REST API root (no trailing slash)
WORDPRESS_API_URL=https://your-wordpress.test/wp-json

# Public WordPress site URL — media + CF7 (no /wp-json)
WORDPRESS_BASE_URL=https://your-wordpress.test

# --- Next.js public URL (required) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: Basic auth for server-side REST (e.g. menu-items 401) ---
# WORDPRESS_APPLICATION_USER=
# WORDPRESS_APPLICATION_PASSWORD=

# --- Homepage slugs (page that renders at /{lang}/) ---
# HOMEPAGE_SLUG=home
# HOMEPAGE_SLUG_NL=home
# HOMEPAGE_SLUG_EN=home

# --- Menus: numeric menu IDs per location + language (REST menu-items) ---
# WP_MENU_PRIMARY_NL=
# WP_MENU_PRIMARY_EN=
# WP_MENU_FOOTER_NL=
# WP_MENU_FOOTER_EN=
# WP_MENU_LEGAL_NL=
# WP_MENU_LEGAL_EN=
# Legacy alias pattern also supported:
# WORDPRESS_MENU_PRIMARY_NL=

# --- On-demand revalidation (POST /api/revalidate) ---
# REVALIDATION_SECRET=

# --- Contact Form 7 ---
# NEXT_PUBLIC_DEFAULT_CF7_FORM_ID=

# --- i18n overrides (defaults: nl, nl+en) ---
# DEFAULT_LOCALE=nl
# SUPPORTED_LOCALES=nl,en

# --- Rare: CPT REST base if different from post type slug ---
# WORDPRESS_SERVICE_REST_BASE=service
# WORDPRESS_TESTIMONIAL_REST_BASE=testimonial
